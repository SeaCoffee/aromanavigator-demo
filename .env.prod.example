# Public site
DOMAIN=example.com
PUBLIC_ORIGIN=https://example.com

# Django
SECRET_KEY=replace-with-a-long-random-secret
DEBUG=False
DJANGO_ALLOWED_HOSTS=example.com,www.example.com
FRONTEND_URL=https://example.com

# Security / proxy
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
CSRF_TRUSTED_ORIGINS=https://example.com
CORS_ALLOWED_ORIGINS=https://example.com
TRUSTED_PROXY_IPS=127.0.0.1/32,172.16.0.0/12

# Database
MYSQL_USER=aroma
MYSQL_PASSWORD=replace-with-strong-password
MYSQL_ROOT_PASSWORD=replace-with-strong-root-password
MYSQL_DATABASE=aromanavigator_demo
MYSQL_TEST_DATABASE=test_aromanavigator_demo
HOST=db
PORT=3306

# Redis / Celery
REDIS_URL=redis://redis:6379/0

# Email
EMAIL_HOST=smtp.example.com
EMAIL_HOST_USER=mailer@example.com
EMAIL_HOST_PASSWORD=replace-with-smtp-secret
EMAIL_PORT=587
DEFAULT_FROM_EMAIL=Aroma Navigator <mailer@example.com>

# Social auth
GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Frontend runtime/build
NEXT_PUBLIC_APP_URL=https://example.com
NEXT_PUBLIC_SITE_URL=https://example.com
NEXT_PUBLIC_API_BASE=https://example.com
API_BASE=http://nextapp:3000
DJANGO_URL=http://app:8000
NEXTAUTH_URL=https://example.com
DJANGO_PROXY_DEBUG=0
DJANGO_CLIENT_DEBUG=0

# Media/static storage
STATIC_ROOT=/var/lib/aromanavigator/static
MEDIA_URL=/userApi/media/
MEDIA_ROOT=/var/lib/aromanavigator/media
PUBLIC_MEDIA_ROOT=/var/lib/aromanavigator/user-media
PUBLIC_MEDIA_BASE_URL=/userApi/media/
PRIVATE_MEDIA_ROOT=/var/lib/aromanavigator/private-media
PUBLIC_MEDIA_STORAGE_BACKEND=django.core.files.storage.FileSystemStorage
PRIVATE_MEDIA_STORAGE_BACKEND=django.core.files.storage.FileSystemStorage
FRAGRANCE_DEFAULT_COVER_IMAGE=template_fragrance_img/default-fragrance.svg

# Gunicorn
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120
