FROM node:20-alpine
WORKDIR /app

COPY package*.json ./
RUN npm ci --no-audit --no-fund

COPY . .

ARG NEXT_PUBLIC_APP_URL
ARG NEXT_PUBLIC_SITE_URL
ARG NEXT_PUBLIC_API_BASE
ARG API_BASE
ARG DJANGO_URL
ARG NEXTAUTH_URL
ARG NEXT_PUBLIC_GOOGLE_CLIENT_ID
ARG NEXT_PUBLIC_FEATURE_SPLITS_ENABLED=false
ARG NEXT_PUBLIC_FEATURE_DECANTS_ENABLED=false
ARG NEXT_PUBLIC_FEATURE_SHOWCASE_SALES_ENABLED=false

ENV NODE_ENV=production
ENV NEXT_PUBLIC_APP_URL=$NEXT_PUBLIC_APP_URL
ENV NEXT_PUBLIC_SITE_URL=$NEXT_PUBLIC_SITE_URL
ENV NEXT_PUBLIC_API_BASE=$NEXT_PUBLIC_API_BASE
ENV API_BASE=$API_BASE
ENV DJANGO_URL=$DJANGO_URL
ENV NEXTAUTH_URL=$NEXTAUTH_URL
ENV NEXT_PUBLIC_GOOGLE_CLIENT_ID=$NEXT_PUBLIC_GOOGLE_CLIENT_ID
ENV NEXT_PUBLIC_FEATURE_SPLITS_ENABLED=$NEXT_PUBLIC_FEATURE_SPLITS_ENABLED
ENV NEXT_PUBLIC_FEATURE_DECANTS_ENABLED=$NEXT_PUBLIC_FEATURE_DECANTS_ENABLED
ENV NEXT_PUBLIC_FEATURE_SHOWCASE_SALES_ENABLED=$NEXT_PUBLIC_FEATURE_SHOWCASE_SALES_ENABLED

RUN npm run build

EXPOSE 3000
CMD ["npm","run","start"]
