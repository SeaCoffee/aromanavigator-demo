# Django demo defaults
SECRET_KEY=demo-only-change-before-production
DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,app
FRONTEND_URL=http://localhost:3000

# Security / proxy
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
CSRF_TRUSTED_ORIGINS=http://localhost,http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:3000,http://127.0.0.1:3000
TRUSTED_PROXY_IPS=127.0.0.1/32,172.16.0.0/12

# Database
MYSQL_USER=aroma
MYSQL_PASSWORD=aroma_demo_password
MYSQL_ROOT_PASSWORD=aroma_demo_root_password
MYSQL_DATABASE=aromanavigator_demo
MYSQL_TEST_DATABASE=test_aromanavigator_demo
HOST=db
PORT=3306

# Redis / Celery
REDIS_URL=redis://redis:6379/0

# Email: Docker compose routes activation and recovery emails to Mailpit.
EMAIL_HOST=mailpit
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_PORT=1025
EMAIL_USE_TLS=False
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=Aroma Navigator Demo <demo@aromanavigator.local>

# Social auth
GOOGLE_CLIENT_ID=

# Media storage
STATIC_ROOT=/var/lib/aromanavigator/static

# PUBLIC_MEDIA_ROOT can be a separate mounted volume for user/public photos.
# PRIVATE_MEDIA_ROOT must not be inside PUBLIC_MEDIA_ROOT and must not be served by nginx.
MEDIA_URL=/userApi/media/
MEDIA_ROOT=/var/lib/aromanavigator/media
PUBLIC_MEDIA_ROOT=/var/lib/aromanavigator/user-media
PUBLIC_MEDIA_BASE_URL=/userApi/media/
PRIVATE_MEDIA_ROOT=/var/lib/aromanavigator/private-media
PUBLIC_MEDIA_STORAGE_BACKEND=django.core.files.storage.FileSystemStorage
PRIVATE_MEDIA_STORAGE_BACKEND=django.core.files.storage.FileSystemStorage

# Defaults / seed media
FRAGRANCE_DEFAULT_COVER_IMAGE=template_fragrance_img/default-fragrance.svg
